<?xml version="1.0" encoding="UTF-8"?>
<!--
  Telecom360-next IIS site root (same folder as index.html).
  Ensures .json / .mjs / .wasm are served with correct MIME so
  Editor export (viewer-shell/manifest.json) and published tours work
  without extra IIS configuration.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <remove fileExtension=".json" />
      <remove fileExtension=".mjs" />
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".mjs" mimeType="application/javascript" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
    </staticContent>
    <directoryBrowse enabled="false" />
  </system.webServer>
</configuration>
