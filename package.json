{
  "name": "telecom360-threejs",
  "version": "1.0.0",
  "private": true,
  "description": "Telecom360 panorama editor & viewer — three.js + TypeScript, IIS static + one-click deploy",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "node server/preview.mjs",
    "start": "node server/preview.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.2",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/three": "^0.172.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
