{
  "name": "telecom360-next",
  "version": "1.0.0",
  "private": true,
  "description": "Telecom360-next panorama editor & viewer — three.js + TypeScript, IIS static (export ZIP + manual copy)",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "node server/preview.mjs",
    "start": "node server/preview.mjs",
    "typecheck": "tsc --noEmit",
    "poc:viewer": "node scripts/poc_viewer_package.mjs",
    "repair:sites": "node scripts/repair_site_packages.mjs",
    "self-check": "node scripts/self_check.mjs",
    "iis:stage": "npm.cmd run build && powershell -ExecutionPolicy Bypass -File scripts/stage_iis_root.ps1"
  },
  "dependencies": {
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.2",
    "tesseract.js": "^7.0.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/three": "^0.172.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
