{
  "name": "telecom360-next",
  "version": "1.0.1",
  "private": true,
  "description": "Telecom360-next panorama editor & viewer — three.js + TypeScript, IIS static (export ZIP + manual copy)",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.mjs",
    "build": "tsc --noEmit && vite build && node scripts/prepare_viewer_shell.mjs",
    "prepare:viewer-shell": "node scripts/prepare_viewer_shell.mjs",
    "preview": "node server/preview.mjs",
    "start": "node server/preview.mjs",
    "typecheck": "tsc --noEmit",
    "self-check": "node scripts/self_check.mjs",
    "release": "node scripts/package_release.mjs",
    "release:no-check": "node scripts/package_release.mjs --no-self-check"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/three": "^0.172.0",
    "express": "^4.21.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
